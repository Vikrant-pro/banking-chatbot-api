            "api",
            "chat",
            "ask"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Security response for sensitive question\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.answer).to.include('never share OTP');",
              "    pm.expect(jsonData.answer).to.include('1800-XXX-XXXX');",
              "});",
              "",
              "pm.test(\"Response is not from cache\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.fromCache).to.be.false;",
              "});",
              "",
              "pm.test(\"Fast response time for security questions\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.responseTimeMs).to.be.below(100);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
