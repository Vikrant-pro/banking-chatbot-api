    {
      "name": "5. Get Conversation History",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/chat/history/user123",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "chat",
            "history",
            "user123"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test(\"History items have required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        const firstItem = jsonData[0];",
              "        pm.expect(firstItem).to.have.property('id');",
              "        pm.expect(firstItem).to.have.property('userId');",
              "        pm.expect(firstItem).to.have.property('sessionId');",
              "        pm.expect(firstItem).to.have.property('question');",
              "        pm.expect(firstItem).to.have.property('answer');",
              "        pm.expect(firstItem).to.have.property('timestamp');",
              "        pm.expect(firstItem).to.have.property('responseTimeMs');",
              "        pm.expect(firstItem).to.have.property('language');",
              "        pm.expect(firstItem).to.have.property('flaggedAsSensitive');",
              "    }",
              "});",
              "",
              "pm.test(\"History is ordered by timestamp (newest first)\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 1) {",
              "        for (let i = 0; i < jsonData.length - 1; i++) {",
              "            const currentTime = new Date(jsonData[i].timestamp).getTime();",
              "            const nextTime = new Date(jsonData[i + 1].timestamp).getTime();",
              "            pm.expect(currentTime).to.be.at.least(nextTime);",
              "        }",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Get Popular Questions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8081/api/chat/popular-questions",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "chat",
            "popular-questions"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Popular questions have question and count\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        jsonData.forEach(function(item) {",
              "            pm.expect(item).to.have.property('question');",
              "            pm.expect(item).to.have.property('count');",
              "            pm.expect(item.count).to.be.a('number').and.be.above(0);",
              "        });",
              "    }",
              "});",
              "",
              "pm.test(\"Questions are ordered by count (highest first)\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 1) {",
              "        for (let i = 0; i < jsonData.length - 1; i++) {",
              "            pm.expect(jsonData[i].count).to.be.at.least(jsonData[i + 1].count);",
              "        }",
              "    }",
              "});",
              "",
              "pm.test(\"Maximum 5 popular questions returned\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.at.most(5);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
