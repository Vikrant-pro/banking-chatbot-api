{
  "info": {
    "name": "Banking Chatbot API - Complete Test Suite",
    "description": "Comprehensive Postman collection for testing the Banking Chatbot REST API with security, audit, and caching features.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "1. Basic Chat Question - Home Loan Interest Rate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"user123\",\n  \"sessionId\": \"sess001\",\n  \"question\": \"What is the current home loan interest rate?\"\n}"
        },
        "url": {
          "raw": "http://localhost:8081/api/chat/ask",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8081",
          "path": [
            "api",
            "chat",
            "ask"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('responseId');",
              "    pm.expect(jsonData).to.have.property('sessionId');",
              "    pm.expect(jsonData).to.have.property('answer');",
              "    pm.expect(jsonData).to.have.property('responseTimeMs');",
              "    pm.expect(jsonData).to.have.property('timestamp');",
              "    pm.expect(jsonData).to.have.property('fromCache');",
              "    pm.expect(jsonData).to.have.property('disclaimer');",
              "});",
              "",
              "pm.test(\"Session ID is returned\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.sessionId).to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test(\"Response time is reasonable\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.responseTimeMs).to.be.above(0).and.below(10000);",
              "});",
              "",
              "pm.test(\"Disclaimer is present\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.disclaimer).to.include('AI assistant');",
              "});",
              "",
              "pm.test(\"Answer contains banking content\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.answer).to.be.a('string').and.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
